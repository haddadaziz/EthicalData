generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Utilisateur {
  id              BigInt    @id @default(autoincrement())
  prenom          String
  nom             String
  email           String    @unique
  telephone       String?
  motDePasse      String
  statut          Statut    @default(ACTIF)
  preferences     Json      @default("{}")
  avatar          String?
  bio             String?   @db.Text
  dateInscription DateTime  @default(now())
  deletedAt       DateTime? @map("deleted_at")

  roles           Role[]           @relation("UtilisateurRoles")
  telechargements Telechargement[]
  tentatives      Tentative[]

  // Relations Coaching & RDV
  creneauxProposes CreneauDisponibilite[] @relation("FormateurCreneaux")
  rdvCandidat      RendezVous[]           @relation("CandidatRendezVous")
  rdvFormateur     RendezVous[]           @relation("FormateurRendezVous")
  coursCrees       Cours[]                @relation("FormateurCours")

  // Relations forum
  sujets                   Sujet[]
  commentaires             Commentaire[]
  commentairesMentionnes   Commentaire[]            @relation("MentionCommentaire")
  likesSujets              LikeSujet[]
  likesCommentaires        LikeCommentaire[]
  signalements             SignalementSujet[]
  signalementsCommentaires SignalementCommentaire[]
  notifications            Notification[]
  inscriptionsCours        InscriptionCours[]       @relation("ApprenantInscriptions")

  @@map("utilisateurs")
}

model Role {
  id  BigInt @id @default(autoincrement())
  nom String @unique

  // Relation inverse
  utilisateurs Utilisateur[] @relation("UtilisateurRoles")

  @@map("roles")
}

model Fournisseur {
  id             BigInt          @id @default(autoincrement())
  nom            String          @unique
  slug           String          @unique
  image          String?
  certifications Certification[]

  @@map("fournisseurs")
}

model CategorieCertification {
  id             BigInt          @id @default(autoincrement())
  nom            String
  slug           String          @unique
  description    String?         @db.Text
  image          String?
  ordre          Int             @default(0)
  certifications Certification[]

  @@map("categories_certifications")
}

model ModuleCertification {
  id              BigInt               @id @default(autoincrement())
  titre           String
  description     String?              @db.Text
  ordre           Int                  @default(0)
  icon            String?

  certificationId BigInt
  certification   Certification        @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  parentId        BigInt?
  parent          ModuleCertification?  @relation("SousModules", fields: [parentId], references: [id], onDelete: Cascade)
  sousModules     ModuleCertification[] @relation("SousModules")

  @@index([certificationId, ordre])
  @@index([parentId])
  @@map("modules_certification")
}

model Certification {
  id              BigInt    @id @default(autoincrement())
  nom             String
  slug            String    @unique
  codeExamen      String?   @unique
  description     String    @db.Text
  niveau          Niveau
  dureeIndicative String?
  objectifs       String[]
  prerequis       String[]
  image           String?
  dateCreation    DateTime  @default(now())
  deletedAt       DateTime? @map("deleted_at")

  fournisseurId BigInt
  fournisseur   Fournisseur  @relation(fields: [fournisseurId], references: [id], onDelete: Cascade)
  ressources    Ressource[]
  questions     Question[]
  cours         Cours[]
  simulations   Simulation[]

  categorieId BigInt?
  categorie   CategorieCertification? @relation(fields: [categorieId], references: [id], onDelete: SetNull)
  modules     ModuleCertification[]

  // Relations forum
  sujets Sujet[]

  @@index([fournisseurId, deletedAt])
  @@index([categorieId])
  @@map("certifications")
}

model Cours {
  id              BigInt      @id @default(autoincrement())
  titre           String
  slug            String      @unique
  description     String?     @db.Text
  statut          StatutCours @default(BROUILLON)
  imageUrl        String?
  videoUrl        String?
  objectifs       String[]    @default([])
  prerequis       String[]    @default([])
  publicCible     String[]    @default([])
  dureeEstimee    Int? // total en minutes
  dateCreation    DateTime    @default(now())
  datePublication DateTime?
  deletedAt       DateTime?   @map("deleted_at")

  // Formateur auteur du cours
  formateurId BigInt      @map("formateur_id")
  formateur   Utilisateur @relation("FormateurCours", fields: [formateurId], references: [id], onDelete: Cascade)

  // Certification préparée par ce cours (optionnelle pour les brouillons)
  certificationId BigInt?        @map("certification_id")
  certification   Certification? @relation(fields: [certificationId], references: [id], onDelete: SetNull)

  // Contenu du cours
  modules      Module[]
  simulations  Simulation[]
  inscriptions InscriptionCours[]
  ressources   Ressource[]

  @@index([certificationId, statut])
  @@index([formateurId, statut])
  @@map("cours")
}

model InscriptionCours {
  id              BigInt    @id @default(autoincrement())
  progression     Int       @default(0) // 0 à 100
  dateInscription DateTime  @default(now()) @map("date_inscription")
  dateFin         DateTime? @map("date_fin")

  coursId BigInt @map("cours_id")
  cours   Cours  @relation(fields: [coursId], references: [id], onDelete: Cascade)

  apprenantId BigInt      @map("apprenant_id")
  apprenant   Utilisateur @relation("ApprenantInscriptions", fields: [apprenantId], references: [id], onDelete: Cascade)

  progressions ProgressionModule[]

  @@unique([coursId, apprenantId])
  @@map("inscriptions_cours")
}

model ProgressionModule {
  id              BigInt   @id @default(autoincrement())
  completed       Boolean  @default(false)
  dateCompletion  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inscriptionCoursId BigInt @map("inscription_cours_id")
  inscription        InscriptionCours @relation(fields: [inscriptionCoursId], references: [id], onDelete: Cascade)

  moduleId BigInt @map("module_id")
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([inscriptionCoursId, moduleId])
  @@map("progressions_modules")
}

model Module {
  id           BigInt   @id @default(autoincrement())
  titre        String
  description  String?  @db.Text
  contenu      String?  @db.Text // leçon rédigée (markdown/HTML)
  ordre        Int      @default(0)
  dureeEstimee Int?     @default(30) // en minutes
  imageUrl     String?
  videoUrl     String?
  dateCreation DateTime @default(now())

  // Cours parent
  coursId BigInt @map("cours_id")
  cours   Cours  @relation(fields: [coursId], references: [id], onDelete: Cascade)

  // Ressources propres à ce module
  ressources Ressource[]
  progressions ProgressionModule[]

  @@index([coursId, ordre])
  @@map("modules")
}

model Ressource {
  id                  BigInt        @id @default(autoincrement())
  titre               String
  description         String?       @db.Text
  type                TypeRessource
  url                 String
  taille              Int? // en octets
  version             String        @default("1.0.0")
  quotaTelechargement Int?          @default(10)
  public              Boolean       @default(false)
  ordre               Int           @default(0)
  dateCreation        DateTime      @default(now())
  deletedAt           DateTime?     @map("deleted_at")

  // Ressource attachée à un Module (optionnel)
  moduleId BigInt? @map("module_id")
  module   Module? @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  // Ressource attachée à un Cours (optionnel)
  coursId BigInt? @map("cours_id")
  cours   Cours?  @relation(fields: [coursId], references: [id], onDelete: SetNull)

  // Ressource attachée directement à une Certification (bibliothèque globale)
  certificationId BigInt?        @map("certification_id")
  certification   Certification? @relation(fields: [certificationId], references: [id], onDelete: SetNull)

  telechargements Telechargement[]

  @@index([moduleId])
  @@index([coursId])
  @@index([certificationId])
  @@map("ressources")
}

model Telechargement {
  id   BigInt   @id @default(autoincrement())
  date DateTime @default(now())
  ip   String?

  // Relations
  ressourceId   BigInt
  ressource     Ressource   @relation(fields: [ressourceId], references: [id], onDelete: Cascade)
  utilisateurId BigInt
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@index([utilisateurId, ressourceId])
  @@map("telechargements")
}

model Question {
  id              BigInt   @id @default(autoincrement())
  enonce          String   @db.Text
  explication     String?  @db.Text
  reponseCorrecte String?  @db.Text
  grilleNotation  String?  @db.Text
  categorie       String?
  type            String   @default("QCM")
  difficulte      Int      @default(1) // 1 à 5
  dateCreation    DateTime @default(now())

  // Une question appartient à une Simulation ET reste traçable vers une Certification
  certificationId BigInt        @map("certification_id")
  certification   Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  simulationId BigInt?     @map("simulation_id")
  simulation   Simulation? @relation(fields: [simulationId], references: [id], onDelete: SetNull)

  options Option[]

  @@index([certificationId])
  @@index([simulationId])
  @@map("questions")
}

model Option {
  id     BigInt @id @default(autoincrement())
  lettre String
  texte  String @db.Text

  questionId BigInt
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("options")
}

model Simulation {
  id           BigInt   @id @default(autoincrement())
  titre        String
  description  String?  @db.Text
  duree        Int      @default(60) // en minutes
  scoreMinimal Int      @default(700) // score pour réussir
  dateCreation DateTime @default(now())
  statut       StatutSimulation @default(BROUILLON)

  // Cours associé
  coursId BigInt? @map("cours_id")
  cours   Cours?  @relation(fields: [coursId], references: [id], onDelete: SetNull)

  // Certification associée (pour les simulations globales sans cours)
  certificationId BigInt        @map("certification_id")
  certification   Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  tentatives Tentative[]
  questions  Question[]

  @@index([coursId])
  @@index([certificationId])
  @@map("simulations")
}

model Tentative {
  id           BigInt   @id @default(autoincrement())
  score        Int
  dureePassage Int? // temps réel passé en secondes
  datePassage  DateTime @default(now())

  utilisateurId BigInt      @map("utilisateur_id")
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  simulationId BigInt     @map("simulation_id")
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@index([utilisateurId, simulationId])
  @@map("tentatives")
}

model Sujet {
  id           BigInt    @id @default(autoincrement())
  titre        String
  contenu      String    @db.Text
  theme        String // Azure, Data, IA, Cybersécurité, Carrière, Examen...
  dateCreation DateTime  @default(now())
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  auteurId        BigInt
  auteur          Utilisateur        @relation(fields: [auteurId], references: [id], onDelete: Cascade)
  certificationId BigInt?
  certification   Certification?     @relation(fields: [certificationId], references: [id], onDelete: SetNull)
  commentaires    Commentaire[]
  likes           LikeSujet[]
  signalements    SignalementSujet[]

  @@index([auteurId])
  @@index([theme])
  @@index([deletedAt])
  @@map("sujets")
}

model Commentaire {
  id                  BigInt        @id @default(autoincrement())
  contenu             String        @db.Text
  dateCreation        DateTime      @default(now())
  deletedAt           DateTime?     @map("deleted_at")
  // Parent / Réponses aux commentaires
  parentCommentaireId BigInt?       @map("parent_commentaire_id")
  parentCommentaire   Commentaire?  @relation("ReponsesCommentaire", fields: [parentCommentaireId], references: [id], onDelete: Cascade)
  reponses            Commentaire[] @relation("ReponsesCommentaire")

  // Relations
  sujetId      BigInt
  sujet        Sujet                    @relation(fields: [sujetId], references: [id], onDelete: Cascade)
  auteurId     BigInt
  auteur       Utilisateur              @relation(fields: [auteurId], references: [id], onDelete: Cascade)
  mentionUserId BigInt?                 @map("mention_user_id")
  mentionUser  Utilisateur?             @relation("MentionCommentaire", fields: [mentionUserId], references: [id], onDelete: SetNull)
  likes        LikeCommentaire[]
  signalements SignalementCommentaire[]

  @@index([sujetId, dateCreation])
  @@map("commentaires")
}

model LikeSujet {
  id       BigInt   @id @default(autoincrement())
  dateLike DateTime @default(now())

  // Relations
  sujetId       BigInt
  sujet         Sujet       @relation(fields: [sujetId], references: [id], onDelete: Cascade)
  utilisateurId BigInt
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@unique([sujetId, utilisateurId])
  @@map("likes_sujets")
}

model LikeCommentaire {
  id       BigInt   @id @default(autoincrement())
  dateLike DateTime @default(now())

  // Relations
  commentaireId BigInt      @map("commentaire_id")
  commentaire   Commentaire @relation(fields: [commentaireId], references: [id], onDelete: Cascade)
  utilisateurId BigInt      @map("utilisateur_id")
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@unique([commentaireId, utilisateurId])
  @@map("likes_commentaires")
}

model SignalementSujet {
  id           BigInt   @id @default(autoincrement())
  motif        String?
  dateCreation DateTime @default(now())
  traite       Boolean  @default(false)

  // Relations
  sujetId       BigInt
  sujet         Sujet       @relation(fields: [sujetId], references: [id], onDelete: Cascade)
  utilisateurId BigInt
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@unique([sujetId, utilisateurId])
  @@index([traite])
  @@map("signalements_sujets")
}

model SignalementCommentaire {
  id           BigInt   @id @default(autoincrement())
  motif        String?
  dateCreation DateTime @default(now()) @map("date_creation")
  traite       Boolean  @default(false)

  // Relations
  commentaireId BigInt      @map("commentaire_id")
  commentaire   Commentaire @relation(fields: [commentaireId], references: [id], onDelete: Cascade)
  utilisateurId BigInt      @map("utilisateur_id")
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@unique([commentaireId, utilisateurId])
  @@index([traite])
  @@map("signalements_commentaires")
}

model Notification {
  id             BigInt      @id @default(autoincrement())
  destinataireId BigInt      @map("destinataire_id")
  titre          String
  message        String      @db.Text
  type           String // "FORUM_REPLY", "FORUM_LIKE", "FORUM_REPORT", "SYSTEM"
  lien           String?
  lue            Boolean     @default(false)
  dateCreation   DateTime    @default(now()) @map("date_creation")
  destinataire   Utilisateur @relation(fields: [destinataireId], references: [id], onDelete: Cascade)

  @@index([destinataireId, lue])
  @@map("notifications")
}

enum StatutCours {
  BROUILLON
  PUBLIE
  ARCHIVE
}

enum StatutSimulation {
  BROUILLON
  PUBLIE
}

enum TypeRessource {
  PDF
  VIDEO
  SLIDE
  DATASET
  LIEN_EXTERNE
  EXERCICE
  AUTRE
}

enum Statut {
  ACTIF
  INACTIF
  BANNI
}

enum Niveau {
  DEBUTANT
  INTERMEDIAIRE
  AVANCE
}

model ContactMessage {
  id        BigInt   @id @default(autoincrement())
  nom       String
  email     String
  sujet     String
  message   String   @db.Text
  lu        Boolean  @default(false)
  dateCreation DateTime @default(now()) @map("date_creation")

  @@map("contact_messages")
}

enum TypeRendezVous {
  ORIENTATION
  COACHING_TECHNIQUE
  PREPARATION_EXAMEN
  BILAN_CARRIERE
}

enum StatutRendezVous {
  CONFIRME
  ANNULE
  TERMINE
}

model CreneauDisponibilite {
  id           BigInt   @id @default(autoincrement())
  dateDebut    DateTime @map("date_debut")
  dateFin      DateTime @map("date_fin")
  estReserve   Boolean  @default(false) @map("est_reserve")
  dateCreation DateTime @default(now()) @map("date_creation")

  // Formateur proposant le créneau
  formateurId BigInt      @map("formateur_id")
  formateur   Utilisateur @relation("FormateurCreneaux", fields: [formateurId], references: [id], onDelete: Cascade)

  // Relation vers le rendez-vous si réservé
  rendezVous RendezVous?

  @@index([formateurId, estReserve])
  @@map("creneaux_disponibilite")
}

model RendezVous {
  id           BigInt           @id @default(autoincrement())
  type         TypeRendezVous   @default(COACHING_TECHNIQUE)
  motif        String?          @db.Text
  notes        String?          @db.Text
  statut       StatutRendezVous @default(CONFIRME)
  dateCreation DateTime         @default(now()) @map("date_creation")

  // Candidat ayant réservé
  candidatId BigInt      @map("candidat_id")
  candidat   Utilisateur @relation("CandidatRendezVous", fields: [candidatId], references: [id], onDelete: Cascade)

  // Formateur encadrant
  formateurId BigInt      @map("formateur_id")
  formateur   Utilisateur @relation("FormateurRendezVous", fields: [formateurId], references: [id], onDelete: Cascade)

  // Créneau associé
  creneauId BigInt               @unique @map("creneau_id")
  creneau   CreneauDisponibilite @relation(fields: [creneauId], references: [id], onDelete: Cascade)

  @@index([candidatId])
  @@index([formateurId])
  @@map("rendez_vous")
}
